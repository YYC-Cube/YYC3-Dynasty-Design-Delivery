{
  "name": "@yyc3/i18n-core",
  "version": "2.4.0",
  "description": "🌐 YYC³ Production-Ready Internationalization (i18n) Framework - High-performance, plugin-based, zero-dependency i18n solution for TypeScript/JavaScript applications",
  "keywords": [
    "i18n",
    "internationalization",
    "localization",
    "translation",
    "typescript",
    "lru-cache",
    "plugin-system",
    "rtl",
    "lit",
    "web-components",
    "yyc3",
    "chinese-i18n",
    "chinese-localization",
    "中文国际化",
    "中文本地化",
    "react-i18n-alternative",
    "vue-i18n-alternative",
    "zero-dependencies",
    "enterprise-i18n",
    "next-i18n",
    "nuxt-i18n",
    "icu-messageformat",
    "mcp",
    "ai-translation",
    "quality-estimation",
    "ast-extraction"
  ],
  "author": "YanYuCloudCube Team <admin@0379.email>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YYC-Cube/YYC3-i18n-Core.git"
  },
  "homepage": "https://github.com/YYC-Cube/YYC3-i18n-Core#readme",
  "bugs": {
    "url": "https://github.com/YYC-Cube/YYC3-i18n-Core/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cache": {
      "import": "./dist/lib/cache.js",
      "types": "./dist/lib/cache.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins/index.js",
      "types": "./dist/plugins/index.d.ts"
    },
    "./icu": {
      "import": "./dist/lib/icu/parser.js",
      "types": "./dist/lib/icu/parser.d.ts"
    },
    "./ai": {
      "import": "./dist/lib/ai/provider.js",
      "types": "./dist/lib/ai/provider.d.ts"
    },
    "./mcp": {
      "import": "./dist/lib/mcp/server.js",
      "types": "./dist/lib/mcp/server.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "lit": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "type": "module",
  "private": false
}
